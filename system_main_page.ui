    <property name="styleSheet">
     <string notr="true">QTreeWidget#change_page
{
    outline: 0px;          /* 去掉焦点虚线边框（选中时不显示虚线） */
    border: none;          /* 去掉控件默认边框，让侧边栏更简洁 */
    background-color: white; /* 整体背景色（改成白色，贴近示例） */
    color: black;          /* 默认文字颜色（未选中时） */
	/*font-size:14px;*/
}

QTreeWidget#change_page::item
{
	margin-top: 5px;       /* 项之间的上边距（让菜单项间隔开） */
    margin-bottom: 5px;    /* 项之间的下边距 */
    height: 30px;          /* 菜单项高度（点击区域更大，更美观） */
    padding: 0px 10px;     /* 内边距：左右留空，文字不贴边 */
    background-color: transparent; /* 默认背景透明，hover/选中时再改 */
    color: rgba(0,0,0,0.8);          /* 未选中时文字黑色 */	
	padding-left: 0px; /* 图标宽度 + 间距（如图标24px + 8px间距 = 32px） */
}
/* 3. 控制分支（Branch，即展开/折叠箭头）的样式 */
QTreeWidget#change_page::branch {
    margin-top: 5px;       
    margin-bottom: 5px;    
    height: 30px;          
    padding: 0px 10px;     
    /*background-color: transparent; /* 分支背景透明 */
}
/* 4. 控制“选中状态”的样式（Item 和 Branch 都要改） */
QTreeWidget#change_page::branch:selected {
    /* 去掉选中时的默认边框（设为透明） */
    border-left-color: transparent;   
    border-right-color: transparent;  
    border-top-color: transparent;    
    border-bottom-color: transparent; 

    /* 新增：让背景显示圆角 */
    border-radius: 4px;            /* 圆角大小，与默认项保持一致 */
    border-top-right-radius: 0px;    /* 右上角有圆角 */
    border-bottom-right-radius: 0px; /* 右下角有圆角 */

    background-color: rgb(59, 130, 246); /* 选中背景色（类似示例的蓝色） */
    color: white;          /* 选中时文字白色 */
}
QTreeWidget#change_page::item:selected {
    /* 去掉选中时的默认边框（设为透明） */
    border-left-color: transparent;   
    border-right-color: transparent;  
    border-top-color: transparent;    
    border-bottom-color: transparent; 

    /* 新增：让背景显示圆角 */
    border-radius: 4px;            /* 圆角大小，与默认项保持一致 */
    border-top-left-radius: 0px;     /* 左上角无圆角 */
    border-bottom-left-radius: 0px;  /* 左下角无圆角 */

    background-color: rgb(59, 130, 246); /* 选中背景色（类似示例的蓝色） */
    color: white;          /* 选中时文字白色 */
} </string>
